# DDoS Protection System - Environment Configuration
# Copy this file to .env and adjust values as needed

# Flask
FLASK_ENV=production
FLASK_PORT=8000

# Admin Authentication (CHANGE THIS IN PRODUCTION!)
ADMIN_API_KEY=change-me-in-production
ADMIN_PASSWORD=change-me-in-production
# Optional bcrypt/pbkdf2 hash. If set, it is preferred over ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=pbkdf2:sha256:...
FLASK_SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=43200
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=300

# Detection Engine
DETECTION_THRESHOLD=50
TIME_WINDOW=60
UNIQUE_IP_THRESHOLD=50
BLOCK_PRIVATE_IPS=true

# Rate Limiter
RATE_LIMIT=100
BURST_SIZE=20

# Health Monitor
FAILURE_THRESHOLD=3
RECOVERY_TIME=300
ATTACK_MITIGATION_DELAY_SECONDS=10
ATTACK_ACTIVITY_WINDOW_SECONDS=30

# Attack Notifications (optional)
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_COOLDOWN=60
ATTACK_LOG_MAXLEN=5000

# GeoIP (optional, for real country/city in dashboard)
# Example:
# GEOIP_DB_PATH=/app/GeoLite2-City.mmdb
# GEOIP_DB_PATH=C:\path\to\GeoLite2-City.mmdb
# GEOIP_SOURCE=auto
# GEOIP_API_URL=https://ipwho.is/{ip}
# GEOIP_API_TIMEOUT=2.0
